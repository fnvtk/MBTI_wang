.history-page {
  min-height: 100vh;
  background: #F5F3FF;
  padding: 24rpx;
}
.item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(124, 58, 237, 0.06);
}
.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F1B4D;
  margin-bottom: 10rpx;
}
.item-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
  font-size: 22rpx;
  color: #6B6894;
}
.mbti-tag {
  background: #EDE9FE;
  color: #7c3aed;
  border-radius: 100rpx;
  padding: 2rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.empty {
  text-align: center;
  color: #9CA3AF;
  padding: 96rpx 0 40rpx;
  font-size: 26rpx;
}
