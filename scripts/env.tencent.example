# 复制为本目录下的 .env.tencent（勿提交仓库）
# 腾讯云 API 密钥：https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# 可选：COS 桶名（形如 bucketname-125xxxx）；不设则脚本会 ListBuckets 自动选一个
# MBTI_COS_BUCKET=

# 可选：默认 ap-guangzhou；桶与 CVM 区域不一致时请按桶地域填写
# MBTI_COS_REGION=ap-guangzhou

# 可选：kr 上部署目标 CVM（默认 ins-aw0tnqjo）
# MBTI_CVM_INSTANCE_ID=ins-aw0tnqjo
